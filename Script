    local minimizeButton = Instance.new("TextButton")
    minimizeButton.Size = UDim2.new(0, 25, 0, 25)
    minimizeButton.Position = UDim2.new(1, -50, 0, 0)
    minimizeButton.BackgroundTransparency = 1
    minimizeButton.Text = "−"
    minimizeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    minimizeButton.TextSize = 18
    minimizeButton.Font = Enum.Font.GothamBold
    minimizeButton.Parent = titleBar

    local buttonsFrame = Instance.new("Frame")
    buttonsFrame.Size = UDim2.new(1, -20, 1, -35)
    buttonsFrame.Position = UDim2.new(0, 10, 0, 30)
    buttonsFrame.BackgroundTransparency = 1
    buttonsFrame.Parent = mainFrame

    local aimbotButton = Instance.new("TextButton")
    aimbotButton.Name = "AimbotButton"
    aimbotButton.Size = UDim2.new(1, 0, 0, 30)
    aimbotButton.Position = UDim2.new(0, 0, 0, 5)
    aimbotButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    aimbotButton.Text = "AIMBOT: OFF"
    aimbotButton.TextColor3 = Color3.fromRGB(255, 100, 100)
    aimbotButton.TextSize = 12
    aimbotButton.Font = Enum.Font.GothamBold
    aimbotButton.BorderSizePixel = 0
    aimbotButton.Parent = buttonsFrame
    local aimbotCorner = Instance.new("UICorner")
    aimbotCorner.CornerRadius = UDim.new(0, 8)
    aimbotCorner.Parent = aimbotButton

    local espButton = Instance.new("TextButton")
    espButton.Name = "ESPButton"
    espButton.Size = UDim2.new(1, 0, 0, 30)
    espButton.Position = UDim2.new(0, 0, 0, 40)
    espButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    espButton.Text = "ESP: OFF"
    espButton.TextColor3 = Color3.fromRGB(255, 100, 100)
    espButton.TextSize = 12
    espButton.Font = Enum.Font.GothamBold
    espButton.BorderSizePixel = 0
    espButton.Parent = buttonsFrame
    local espCorner = Instance.new("UICorner")
    espCorner.CornerRadius = UDim.new(0, 8)
    espCorner.Parent = espButton

    local minimized = false
    local dragging = false
    local dragStart, startPos

    local function updateButton(button, enabled, text)
        if enabled then
            button.Text = text .. ": ON"
            button.TextColor3 = Color3.fromRGB(100, 255, 100)
            local grad = button:FindFirstChild("Gradient")
            if not grad then
                grad = Instance.new("UIGradient")
                grad.Name = "Gradient"
                grad.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 255, 255)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 150, 150))
                })
                grad.Rotation = 90
                grad.Parent = button
            end
        else
            button.Text = text .. ": OFF"
            button.TextColor3 = Color3.fromRGB(255, 100, 100)
            local grad = button:FindFirstChild("Gradient")
            if grad then grad:Destroy() end
        end
    end

    aimbotButton.MouseButton1Click:Connect(function()
        aimbotEnabled = not aimbotEnabled
        updateButton(aimbotButton, aimbotEnabled, "AIMBOT")
    end)

    espButton.MouseButton1Click:Connect(function()
        espEnabled = not espEnabled
        updateButton(espButton, espEnabled, "ESP")
        if espEnabled then startESP() else stopESP() end
    end)

    closeButton.MouseButton1Click:Connect(function()
        stopESP()
        screenGui:Destroy()
    end)

    minimizeButton.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            TweenService:Create(buttonsFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {
                Size = UDim2.new(1, -20, 0, 0)
            }):Play()
            TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {
                Size = UDim2.new(0, 140, 0, 25)
            }):Play()
        else
            TweenService:Create(buttonsFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {
                Size = UDim2.new(1, -20, 1, -35)
            }):Play()
            TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {
                Size = UDim2.new(0, 140, 0, 100)
            }):Play()
        end
    end)

    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)

    titleBar.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
            local delta = input.Position - dragStart
            local newPos = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
            local clampedX = math.clamp(newPos.X.Offset, 0, camera.ViewportSize.X - mainFrame.AbsoluteSize.X)
            local clampedY = math.clamp(newPos.Y.Offset, 0, camera.ViewportSize.Y - mainFrame.AbsoluteSize.Y)
            mainFrame.Position = UDim2.new(0, clampedX, 0, clampedY)
        end
    end)

    return screenGui
end

createUI()

localPlayer.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoidRootPart = character:WaitForChild("HumanoidRootPart")
end)

Players.PlayerAdded:Connect(function(player)
    if espEnabled and player ~= localPlayer then
        createESPForPlayer(player)
    end
end)

Players.PlayerRemoving:Connect(function(player)
    if espEnabled then removeESPForPlayer(player) end
end)

RunService.RenderStepped:Connect(function()
    if aimbotEnabled then
        if tick() - lastShotTime >= AIMBOT_CONFIG.Cooldown then
            fireAimbot()
        end
    end
end)
