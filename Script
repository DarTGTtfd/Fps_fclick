local function onAimbotV2Update()
    if not aimbotV2Enabled then
        if v2Connection then
            v2Connection:Disconnect()
            v2Connection = nil
        end
        if targetHighlight then
            targetHighlight:Destroy()
            targetHighlight = nil
        end
        v2Target = nil
        return
    end

    if not v2Target or not v2Target.Character or v2Target.Character.Humanoid.Health <= 0 then
        v2Target = getClosestInFOV()
        updateTargetHighlight()
    end

    if v2Target and tick() - lastAttackV2 >= AIMBOTV2_CONFIG.Cooldown then
        local targetHead = v2Target.Character and v2Target.Character:FindFirstChild("Head")
        if targetHead then
            camera.CFrame = CFrame.new(camera.CFrame.Position, targetHead.Position)
        end
        fireGunAttack(v2Target)
        lastAttackV2 = tick()
    end
end

