local function findRemotes()
    local function search(name)
        for _, v in pairs(ReplicatedStorage:GetDescendants()) do
            if v:IsA("RemoteEvent") and v.Name:lower():find(name:lower()) then
                return v
            end
        end
        return nil
    end
    projectileRemote = search("ProjectileRender") or ReplicatedStorage.ModuleScripts.GunModules.Remote.ProjectileRender
    checkShotRemote = localPlayer.ClientRemotes and localPlayer.ClientRemotes.CheckShot
    finishRemote = search("ProjectileFinished") or ReplicatedStorage.ModuleScripts.GunModules.Remote.ProjectileFinished
end
findRemotes()

