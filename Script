local AIMBOT_CONFIG = {
    FOV_Radius = 200,
    PredictionMultiplier = 1.5,
    Cooldown = 0.08,
    AimPartPriority = {"Head", "UpperTorso", "HumanoidRootPart"},
    WallCheck = true
}

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")

local localPlayer = Players.LocalPlayer
local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
local camera = Workspace.CurrentCamera

local aimbotEnabled = false
local espEnabled = false
local espFolder = nil
local lastShotTime = 0

local function createESPFolder()
    if espFolder then espFolder:Destroy() end
    espFolder = Instance.new("Folder")
    espFolder.Name = "ESP_Folder"
    espFolder.Parent = CoreGui
end

local function createESPForPlayer(player)
    if player == localPlayer then return end
    local playerFolder = Instance.new("Folder")
    playerFolder.Name = player.Name
    playerFolder.Parent = espFolder

    local highlight = Instance.new("Highlight")
    highlight.Name = "Highlight"
    highlight.FillColor = Color3.fromRGB(0, 255, 255)
    highlight.FillTransparency = 0.7
    highlight.OutlineColor = Color3.fromRGB(0, 255, 255)
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = playerFolder

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "Billboard"
    billboard.Size = UDim2.new(0, 200, 0, 45)
    billboard.StudsOffset = Vector3.new(0, 3.5, 0)
    billboard.AlwaysOnTop = true
    billboard.MaxDistance = 1000
    billboard.Parent = playerFolder

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Name = "NameLabel"
    nameLabel.Size = UDim2.new(1, 0, 0, 20)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.Name
    nameLabel.TextColor3 = Color3.fromRGB(0, 255, 255)
    nameLabel.TextSize = 14
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    nameLabel.Parent = billboard

    local healthBackground = Instance.new("Frame")
    healthBackground.Name = "HealthBackground"
    healthBackground.Size = UDim2.new(1, 0, 0, 4)
    healthBackground.Position = UDim2.new(0, 0, 0, 22)
    healthBackground.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    healthBackground.BorderSizePixel = 0
    healthBackground.Parent = billboard

    local healthBar = Instance.new("Frame")
    healthBar.Name = "HealthBar"
    healthBar.Size = UDim2.new(1, 0, 1, 0)
    healthBar.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    healthBar.BorderSizePixel = 0
    healthBar.Parent = healthBackground

    local healthText = Instance.new("TextLabel")
    healthText.Name = "HealthText"
    healthText.Size = UDim2.new(1, 0, 0, 15)
    healthText.Position = UDim2.new(0, 0, 0, 28)
    healthText.BackgroundTransparency = 1
    healthText.Text = "100 HP"
    healthText.TextColor3 = Color3.fromRGB(255, 255, 255)
    healthText.TextSize = 11
    healthText.Font = Enum.Font.Gotham
    healthText.TextStrokeTransparency = 0
    healthText.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    healthText.Parent = billboard

    local function attachToCharacter(character)
        if not character then return end
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        local head = character:FindFirstChild("Head")
        if rootPart and head then
            highlight.Parent = character
            billboard.Parent = head
            highlight.Enabled = true
            billboard.Enabled = true
        end
    end

    local function updateDisplay()
        local char = player.Character
        if not char then
            highlight.Enabled = false
            billboard.Enabled = false
            return
        end
        local humanoid = char:FindFirstChild("Humanoid")
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")
        if not humanoid or not rootPart or not head then
            highlight.Enabled = false
            billboard.Enabled = false
            return
        end
        if humanoid.Health <= 0 then
            highlight.Enabled = false
            billboard.Enabled = false
            return
        end
        if highlight.Parent ~= char then highlight.Parent = char end
        if billboard.Parent ~= head then billboard.Parent = head end
        highlight.Enabled = true
        billboard.Enabled = true
        local healthPercent = humanoid.Health / humanoid.MaxHealth
        healthBar.Size = UDim2.new(math.clamp(healthPercent, 0, 1), 0, 1, 0)
        healthText.Text = math.floor(humanoid.Health) .. " HP"
        if healthPercent > 0.6 then
            healthBar.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        elseif healthPercent > 0.3 then
            healthBar.BackgroundColor3 = Color3.fromRGB(255, 255, 0)
        else
            healthBar.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        end
        if localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local distance = math.floor((localPlayer.Character.HumanoidRootPart.Position - rootPart.Position).Magnitude)
            nameLabel.Text = player.Name .. " [" .. distance .. "m]"
        else
            nameLabel.Text = player.Name
        end
    end

    local updateConnection
    updateConnection = RunService.RenderStepped:Connect(function()
        if not espEnabled then
            if updateConnection then updateConnection:Disconnect() end
            return
        end
        updateDisplay()
    end)

    player.CharacterAdded:Connect(function(newCharacter)
        task.wait(0.1)
        attachToCharacter(newCharacter)
    end)

    if player.Character then
        attachToCharacter(player.Character)
    end
end

local function removeESPForPlayer(player)
    if not espFolder then return end
    local folder = espFolder:FindFirstChild(player.Name)
    if folder then folder:Destroy() end
end

local function startESP()
    if espFolder then espFolder:Destroy() end
    createESPFolder()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= localPlayer then createESPForPlayer(player) end
    end
end

local function stopESP()
    if espFolder then
        espFolder:Destroy()
        espFolder = nil
    end
end

local function raycastVisibility(origin, targetPosition)
    if not AIMBOT_CONFIG.WallCheck then return true end
    local direction = targetPosition - origin
    local distance = direction.Magnitude
    if distance == 0 then return false end
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.FilterDescendantsInstances = {character}
    local result = Workspace:Raycast(origin, direction.Unit * distance, rayParams)
    return result == nil
end

local function getBestTarget()
    local bestTarget = nil
    local bestScore = math.huge
    local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)

    for _, player in pairs(Players:GetPlayers()) do
        if player == localPlayer then continue end
        local char = player.Character
        if not char then continue end
        local humanoid = char:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end

        local targetPart = nil
        for _, partName in ipairs(AIMBOT_CONFIG.AimPartPriority) do
            local part = char:FindFirstChild(partName)
            if part then
                targetPart = part
                break
            end
        end
        if not targetPart then continue end

        local screenPosition, onScreen = camera:WorldToScreenPoint(targetPart.Position)
        if not onScreen then continue end
        local distanceFromCenter = (Vector2.new(screenPosition.X, screenPosition.Y) - screenCenter).Magnitude
        if distanceFromCenter > AIMBOT_CONFIG.FOV_Radius then continue end

        local gunPos = humanoidRootPart.Position + Vector3.new(0, 1.5, 0)
        if not raycastVisibility(gunPos, targetPart.Position) then continue end

        local score = distanceFromCenter
        if score < bestScore then
            bestScore = score
            bestTarget = {
                Player = player,
                Part = targetPart,
                Humanoid = humanoid,
                RootPart = char:FindFirstChild("HumanoidRootPart")
            }
        end
    end
    return bestTarget
end

local function predictTargetPosition(targetPart, targetRoot, humanoid)
    local velocity = Vector3.zero
    if humanoid and humanoid.MoveDirection.Magnitude > 0 then
        velocity = humanoid.MoveDirection * humanoid.WalkSpeed
    elseif targetRoot then
        velocity = targetRoot.AssemblyLinearVelocity
    end
    local ping = Players:GetNetworkPing() or 0.1
    local predictionTime = math.min(ping * AIMBOT_CONFIG.PredictionMultiplier, 0.5)
    return targetPart.Position + velocity * predictionTime
end

local function fireAimbot()
    local target = getBestTarget()
    if not target then return end
    local targetPart = target.Part
    local targetRoot = target.RootPart
    local targetHumanoid = target.Humanoid
    if not targetPart or not targetRoot or not targetHumanoid then return end
    if targetHumanoid.Health <= 0 then return end

    local gunPosition = humanoidRootPart.Position + Vector3.new(0, 1.5, 0)
    local predictedPos = predictTargetPosition(targetPart, targetRoot, targetHumanoid)
    if not raycastVisibility(gunPosition, predictedPos) then
        predictedPos = targetPart.Position
    end

    local currentTime = tick()
    if currentTime - lastShotTime < AIMBOT_CONFIG.Cooldown then return end
    lastShotTime = currentTime

    local projectileArgs = {
        {
            Type = "Bullet",
            Index = currentTime,
            Origin = gunPosition,
            Owner = character,
            Endpoint = predictedPos,
            Life = 5,
            Force = 130,
            Gravity = 0,
            Wind = Vector3.zero
        }
    }
    pcall(function()
        ReplicatedStorage.ModuleScripts.GunModules.Remote.ProjectileRender:FireServer(unpack(projectileArgs))
    end)

    task.wait(0.05)

    local checkShotArgs = {
        0, 0, 1, 0.8,
        CFrame.lookAt(gunPosition, predictedPos),
        gunPosition,
        targetPart,
        11,
        currentTime
    }
    pcall(function()
        localPlayer.ClientRemotes.CheckShot:FireServer(unpack(checkShotArgs))
    end)

    local finishArgs = {
        {
            Index = currentTime,
            Origin = gunPosition,
            CFrame = CFrame.lookAt(predictedPos, gunPosition),
            ExpRadius = 15,
            LaserColor = Color3.new(0, 1, 1),
            LaserSpeed = 10,
            LaserTime = 0.7,
            Effect = "GibT",
            ExpColor = Color3.new(1, 0.6, 0.2),
            LaserTexture = "rbxassetid://4813348676",
            Explosive = false,
            HitPlayer = true,
            IsLaser = false,
            LaserWidth = 3,
            ExpSound = "rbxassetid://2814354338",
            LaserLength = 5,
            LaserEmission = 1
        }
    }
    pcall(function()
        ReplicatedStorage.ModuleScripts.GunModules.Remote.ProjectileFinished:FireServer(unpack(finishArgs))
    end)
end

